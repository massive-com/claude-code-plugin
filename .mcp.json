{
  "mcpServers": {
    "massive": {
      "command": "uvx",
      "args": [
        "--refresh",
        "--from",
        "git+https://github.com/massive-com/mcp_massive",
        "mcp_massive"
      ],
      "env": {
        "MASSIVE_API_KEY": "${user_config.massive_api_key}"
      }
    }
  }
}
